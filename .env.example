# Engagement Tracker — Environment Variables
# Copy this file to .env and customize for your environment.
# Usage: docker compose up --build

# MySQL root password (used by both db and api containers)
DB_ROOT_PASSWORD=localdev

# JWT signing secret (minimum 32 characters for HMAC-SHA256)
JWT_SECRET=dev-secret-key-minimum-32-characters-long-for-hmac-sha256
